  "description": "Component driver for shadcn/ui (re-export of the Radix UI v1 drivers)",
  "repository": {
    "type": "git",
    "url": "https://github.com/atomic-testing/atomic-testing.git",
    "directory": "packages/component-driver-shadcn-v1"
  },
  "files": [
