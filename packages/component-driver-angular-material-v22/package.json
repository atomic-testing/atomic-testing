{
  "name": "@atomic-testing/component-driver-angular-material-v22",
  "version": "0.98.0",
  "description": "Component driver for Angular Material v22",
  "keywords": [
    "angular",
    "angular-material",
    "integration",
    "material",
    "testing",
    "unit"
  ],
  "license": "MIT",
  "author": "Tianzhen Lin <tangent@usa.net>",
  "repository": {
    "type": "git",
    "url": "https://github.com/atomic-testing/atomic-testing.git",
    "directory": "packages/component-driver-angular-material-v22"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check:type": "tsgo --noEmit"
  },
  "dependencies": {
    "@angular/cdk": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@atomic-testing/angular-22": "workspace:*",
    "@atomic-testing/component-driver-html": "workspace:*",
    "@atomic-testing/core": "workspace:*",
    "@atomic-testing/dom-core": "workspace:*"
  },
  "devDependencies": {
    "@angular/common": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "rxjs": "^7.8.0"
  }
}
