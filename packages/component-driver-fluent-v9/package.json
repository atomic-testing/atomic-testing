{
  "name": "@atomic-testing/component-driver-fluent-v9",
  "version": "0.99.0",
  "description": "Component driver for Fluent UI v9 (\"Fluent 2\") React components (@fluentui/react-components)",
  "repository": {
    "type": "git",
    "url": "https://github.com/atomic-testing/atomic-testing.git",
    "directory": "packages/component-driver-fluent-v9"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check:type": "tsc --noEmit"
  },
  "dependencies": {
    "@atomic-testing/component-driver-html": "workspace:*",
    "@atomic-testing/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": ">=18.0.0",
    "@types/react-dom": ">=18.0.0"
  },
  "peerDependencies": {
    "@fluentui/react-components": "^9.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
