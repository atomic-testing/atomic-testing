  "dependencies": {
    "@atomic-testing/core": "workspace:*",
    "@atomic-testing/dom-core": "workspace:*"
  },
  "devDependencies": {
    "storybook": "^10.4.6"
  },
  "peerDependencies": {
    "storybook": "^10.0.0"
  }
}
