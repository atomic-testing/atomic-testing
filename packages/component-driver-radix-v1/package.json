{
  "name": "@atomic-testing/component-driver-radix-v1",
  "version": "0.97.0",
  "description": "Component driver for Radix UI primitives (radix-ui v1)",
  "repository": {
    "type": "git",
    "url": "https://github.com/atomic-testing/atomic-testing.git",
    "directory": "packages/component-driver-radix-v1"
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check:type": "tsgo --noEmit"
  },
  "dependencies": {
    "@atomic-testing/component-driver-html": "workspace:*",
    "@atomic-testing/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": ">=18.0.0",
    "@types/react-dom": ">=18.0.0"
  },
  "peerDependencies": {
    "cmdk": "^1.0.0",
    "radix-ui": "^1.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "cmdk": {
      "optional": true
    }
  }
}
