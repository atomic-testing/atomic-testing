{
  "name": "development-environment",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": "Tianzhen Lin <tangent@usa.net>",
  "repository": {
    "type": "git",
    "url": "https://github.com/atomic-testing/atomic-testing.git"
  },
  "scripts": {
    "build:packages": "./publish.sh --build-only",
    "setup": "pnpm install && pnpm -C docs install --ignore-workspace",
    "docs:dev": "pnpm build:packages && pnpm -C docs start",
    "check:type": "pnpm -r check:type",
    "check:api": "pnpm -r check:api",
    "check:lint": "oxlint --fix",
    "check:style": "oxfmt --ignore-path .gitignore --ignore-path .oxfmtignore",
    "typedoc": "typedoc --out typedocs",
    "bumpVersion": "node scripts/bumpVersion.js",
    "changelog": "node scripts/generateChangelog.js"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.9",
    "@playwright/test": "^1.61.1",
    "@swc/jest": ">=0.2.37",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.3",
    "@typescript/native-preview": "7.0.0-dev.20260616.1",
    "@vitejs/plugin-react": "^6.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsdown": "^0.22.5",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=22.12",
    "pnpm": ">=10"
  },
  "pnpm": {
    "overrides": {
      "form-data": ">=4.0.6",
      "glob@10": ">=10.5.0",
      "minimatch@3": ">=3.1.4",
      "minimatch@5": ">=5.1.8",
      "minimatch@9": ">=9.0.7",
      "picomatch": ">=2.3.2",
      "lodash": ">=4.18.0",
      "fast-uri": ">=3.1.2",
      "js-cookie": ">=3.0.7",
      "tmp": ">=0.2.6",
      "ws": ">=8.21.0",
      "js-yaml@3": ">=3.15.0",
      "ajv": ">=8.18.0",
      "brace-expansion@1": ">=1.1.13",
      "brace-expansion@2": ">=2.0.3",
      "yaml@1": ">=1.10.3",
      "uuid": ">=11.1.1",
      "@tootallnate/once": ">=2.0.1",
      "esbuild": ">=0.28.1",
      "@babel/core": ">=7.29.6"
    }
  }
}
