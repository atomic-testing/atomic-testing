typedocs/**/*
CNAME
# API Extractor reports — oxfmt reformats the embedded TS code fence and breaks
# the byte-exact `check:api` gate. They are generated, never hand-edited.
**/etc/**/*

# Generated by docs/scripts/genSupportMatrix.mjs — owned by the generator, not oxfmt
docs/src/generated/**

# Generated by scripts/skills/gen-skill-content.mjs — byte-exact against .claude/skills/,
# owned by the generator (and its check:skill-sync freshness gate), not oxfmt.
**/skillContent.generated.ts

# Claude Code skill prose is the hand-authored source of truth that the
# scaffolder embeds verbatim (skillContent.generated.ts) — keep oxfmt's markdown
# reformatting off it, or the embed drifts from source on every format run.
.claude/skills/**
