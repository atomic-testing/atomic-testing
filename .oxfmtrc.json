{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "trailingComma": "es5",
  "arrowParens": "avoid",
  "bracketSameLine": true,
  "bracketSpacing": true,
  "proseWrap": "preserve",
  "sortImports": {
    "newlinesBetween": true
  }
}
