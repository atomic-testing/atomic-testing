{
  "sandbox": {
    "network": {
      "allowedDomains": ["registry.npmjs.org", "npm.jsr.io", "github.com", "*.github.com"]
    },
    "excludedCommands": ["gh"]
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebSearch",
      "Bash(pnpm install:*)",
      "Bash(gh:*)",
      "Bash(pnpm --version:*)",
      "Bash(pnpm -C projects/core tsc:*)",
      "Bash(pnpm tsc:*)",
      "Bash(pnpm test:*)",
      "Bash(sl status:*)",
      "Bash(sl log:*)",
      "Bash(sl diff:*)",
      "Bash(pnpm check:lint:*)",
      "Bash(timeout 90s pnpm test:*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/detect-scm.sh\""
          }
        ]
      }
    ]
  }
}
